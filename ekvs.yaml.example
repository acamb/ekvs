# ekvs.yaml — example configuration for the EKVS server
# Copy this file to ekvs.yaml and edit as needed.
# Environment variables override values in this file:
#   EKVS_SERVER_ADDR, EKVS_STORAGE_PATH, EKVS_KEYS_DIR, EKVS_LOG_LEVEL

server_addr:  "0.0.0.0:8080"
storage_path: "./data"
keys_dir:     "./data/.keys"
log_level:    "info"

